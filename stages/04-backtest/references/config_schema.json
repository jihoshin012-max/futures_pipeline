  "M1": {
    "stop_ticks": 135,
    "leg_targets": [50, 120, 240],
    "trail_steps": [
      {"trigger_ticks": 30, "new_stop_ticks": 0},
      {"trigger_ticks": 60, "new_stop_ticks": 20},
      {"trigger_ticks": 120, "new_stop_ticks": 50},
      {"trigger_ticks": 200, "new_stop_ticks": 100}
    ],
    "time_cap_bars": 80
  }
}
